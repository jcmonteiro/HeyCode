{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "speech": {
      "template": "",
      "description": "Toggle speech recording or transcribe an audio file"
    }
  },
  "permission": {
    "bash": {
      "pnpm *": "allow",
      "npx biome *": "allow",
      "biome *": "allow",
      "tsc *": "allow",
      "tsc": "allow",
      "vite *": "allow",
      "vitest *": "allow",
      "mise *": "allow",
      "./scripts/merge-worktrees.sh": "allow",
      "./scripts/merge-worktrees.sh *": "allow"
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".opencode/node_modules/**",
      "bin/**",
      "dist/**",
      "build/**"
    ]
  }
}
